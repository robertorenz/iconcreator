<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================
         IconCreator Studio – Professional palette (no purple)
         Dark slate / steel-blue with a clean blue accent.
         ============================================================ -->

    <!-- Surfaces -->
    <Color x:Key="Clr.Window">#FF1B1F24</Color>
    <Color x:Key="Clr.Panel">#FF23282F</Color>
    <Color x:Key="Clr.PanelAlt">#FF2B313A</Color>
    <Color x:Key="Clr.Elevated">#FF313842</Color>
    <Color x:Key="Clr.Border">#FF3B434E</Color>
    <Color x:Key="Clr.BorderStrong">#FF4C5563</Color>

    <!-- Text -->
    <Color x:Key="Clr.Text">#FFE9EDF2</Color>
    <Color x:Key="Clr.TextDim">#FFA7B0BC</Color>
    <Color x:Key="Clr.TextFaint">#FF6C7581</Color>

    <!-- Accent (steel blue / teal) -->
    <Color x:Key="Clr.Accent">#FF2F81D6</Color>
    <Color x:Key="Clr.AccentHover">#FF3D93EC</Color>
    <Color x:Key="Clr.AccentPressed">#FF2670BC</Color>
    <Color x:Key="Clr.Teal">#FF1F9E8F</Color>

    <!-- Status -->
    <Color x:Key="Clr.Success">#FF2FA36B</Color>
    <Color x:Key="Clr.Warning">#FFD9A335</Color>
    <Color x:Key="Clr.Danger">#FFCF5B5B</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="Brush.Window" Color="{StaticResource Clr.Window}"/>
    <SolidColorBrush x:Key="Brush.Panel" Color="{StaticResource Clr.Panel}"/>
    <SolidColorBrush x:Key="Brush.PanelAlt" Color="{StaticResource Clr.PanelAlt}"/>
    <SolidColorBrush x:Key="Brush.Elevated" Color="{StaticResource Clr.Elevated}"/>
    <SolidColorBrush x:Key="Brush.Border" Color="{StaticResource Clr.Border}"/>
    <SolidColorBrush x:Key="Brush.BorderStrong" Color="{StaticResource Clr.BorderStrong}"/>
    <SolidColorBrush x:Key="Brush.Text" Color="{StaticResource Clr.Text}"/>
    <SolidColorBrush x:Key="Brush.TextDim" Color="{StaticResource Clr.TextDim}"/>
    <SolidColorBrush x:Key="Brush.TextFaint" Color="{StaticResource Clr.TextFaint}"/>
    <SolidColorBrush x:Key="Brush.Accent" Color="{StaticResource Clr.Accent}"/>
    <SolidColorBrush x:Key="Brush.AccentHover" Color="{StaticResource Clr.AccentHover}"/>
    <SolidColorBrush x:Key="Brush.AccentPressed" Color="{StaticResource Clr.AccentPressed}"/>
    <SolidColorBrush x:Key="Brush.Teal" Color="{StaticResource Clr.Teal}"/>
    <SolidColorBrush x:Key="Brush.Success" Color="{StaticResource Clr.Success}"/>
    <SolidColorBrush x:Key="Brush.Warning" Color="{StaticResource Clr.Warning}"/>
    <SolidColorBrush x:Key="Brush.Danger" Color="{StaticResource Clr.Danger}"/>

</ResourceDictionary>
